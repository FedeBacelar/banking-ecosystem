KEYCLOAK_PORT=8090
# Full public URL used by issuer metadata and customer email links.
KEYCLOAK_PUBLIC_URL=http://localhost:8090
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
HOME_BANKING_BFF_OAUTH_CLIENT_SECRET=local-bff-secret
ONBOARDING_INTERNAL_OAUTH_CLIENT_SECRET=local-onboarding-secret
ONBOARDING_BFF_INTERNAL_OAUTH_CLIENT_SECRET=local-onboarding-bff-secret
HOME_BANKING_INTERNAL_OAUTH_CLIENT_SECRET=local-home-banking-service-secret
ACCOUNT_INTERNAL_OAUTH_CLIENT_SECRET=local-account-secret
# Origin only, without a trailing slash.
BANKING_FRONTEND_URL=http://localhost:4200
# Mailpit defaults for local development. Do not add real provider credentials here.
KEYCLOAK_LOCAL_SMTP_HOST=host.docker.internal
KEYCLOAK_LOCAL_SMTP_PORT=1025
KEYCLOAK_LOCAL_SMTP_FROM=no-reply@nerva.local
KEYCLOAK_LOCAL_SMTP_USERNAME=
KEYCLOAK_LOCAL_SMTP_PASSWORD=
KEYCLOAK_LOCAL_SMTP_AUTH=false
KEYCLOAK_LOCAL_SMTP_STARTTLS=false
KEYCLOAK_LOCAL_SMTP_SSL=false
