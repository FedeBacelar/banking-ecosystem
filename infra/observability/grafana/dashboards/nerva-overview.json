          "width": 220
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"api-gateway\",uri!~\".*actuator.*\"}[5m])) or vector(0)",
          "legendFormat": "API Gateway",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Tráfico de entrada",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Respuestas HTTP 5xx por segundo. Una línea en cero confirma que no hubo errores de servidor.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 9,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "width": 240
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"api-gateway|home-banking-bff|.*-service\",status=~\"5..\",uri!~\".*actuator.*\"}[5m])) or on (job) sum by (job) (0 * up{job=~\"api-gateway|home-banking-bff|.*-service\"})",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Errores HTTP 5xx por servicio",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Muestra el servicio con el p95 más alto en cada instante. El diagnóstico por servicio permite revisar el detalle.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "width": 220
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(1, histogram_quantile(0.95, sum by (job, le) (rate(http_server_requests_seconds_bucket{job=~\"api-gateway|home-banking-bff|.*-service\",uri!~\".*actuator.*\"}[5m]))))",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Servicio con mayor latencia p95",
      "type": "timeseries"
    }
