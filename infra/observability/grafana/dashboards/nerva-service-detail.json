{
  "annotations": {
    "list": []
  },
  "description": "Diagnóstico técnico reutilizable para cualquiera de los ocho servicios observables de Nerva.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "nerva-navigation"
      ],
      "targetBlank": false,
      "title": "Navegación Nerva",
      "tooltip": "Abrir otro dashboard de Nerva",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Estado actual",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Confirma que Prometheus puede consultar el servicio seleccionado.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "No disponible"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "Disponible"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "up{job=\"$service\"}",
          "instant": true,
          "legendFormat": "$service",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Disponibilidad",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "decimals": 3,
          "noValue": "0",
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"$service\",uri!~\".*actuator.*\"}[5m])) or vector(0)",
          "instant": true,
          "legendFormat": "Tráfico actual",
          "range": false,
          "refId": "A"
        }
      ],
      "description": "Solicitudes por segundo recibidas por el servicio durante los últimos cinco minutos.",
      "title": "Tráfico actual",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "noValue": "0",
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(increase(http_server_requests_seconds_count{job=\"$service\",status=~\"5..\",uri!~\".*actuator.*\"}[$__range])) or vector(0)",
          "instant": true,
          "legendFormat": "Errores 5xx",
          "range": false,
          "refId": "A"
        }
      ],
      "description": "Cantidad de respuestas 5xx dentro del rango temporal seleccionado.",
      "title": "Errores 5xx",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "decimals": 3,
          "noValue": "Sin tráfico",
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$service\",uri!~\".*actuator.*\"}[5m])))",
          "instant": true,
          "legendFormat": "Latencia p95 actual",
          "range": false,
          "refId": "A"
        }
      ],
      "description": "Percentil 95 de la latencia HTTP del servicio durante los últimos cinco minutos.",
      "title": "Latencia p95 actual",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 6,
      "title": "Comportamiento HTTP",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Tráfico HTTP recibido por cada servicio, sin incluir endpoints operativos de Actuator.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "width": 220
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"$service\",uri!~\".*actuator.*\"}[5m]))",
          "legendFormat": "$service",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Tráfico HTTP",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Errores de cliente y servidor separados por código de estado. Una línea en cero indica ausencia de errores.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 8,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"$service\",status=~\"[45]..\",uri!~\".*actuator.*\"}[5m])) or on () label_replace(vector(0), \"status\", \"sin errores\", \"\", \"\")",
          "legendFormat": "{{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Respuestas HTTP 4xx/5xx",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "El percentil 95 indica el tiempo por debajo del cual finalizó el 95 % de las solicitudes HTTP.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 9,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$service\",uri!~\".*actuator.*\"}[5m])))",
          "legendFormat": "$service",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Latencia HTTP p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 10,
      "title": "Recursos del proceso",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Porcentaje del máximo de heap JVM utilizado por cada servicio.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "id": 11,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "width": 150
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(jvm_memory_used_bytes{job=\"$service\",area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"$service\",area=\"heap\"} > 0)",
          "legendFormat": "$service",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Memoria JVM utilizada",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Porcentaje del máximo de conexiones ocupado en cada pool de base de datos.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent",
          "noValue": "No aplica"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "id": 12,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "width": 150
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(hikaricp_connections_active{job=\"$service\"}) / sum(hikaricp_connections_max{job=\"$service\"})",
          "legendFormat": "$service",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Utilización del pool de conexiones",
      "type": "timeseries"
    },
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "id": 13,
      "panels": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "description": "Advertencias, errores y eventos funcionales del servicio seleccionado.",
          "gridPos": {
            "h": 11,
            "w": 24,
            "x": 0,
            "y": 36
          },
          "id": 14,
          "options": {
            "dedupStrategy": "none",
            "enableInfiniteScrolling": false,
            "enableLogDetails": true,
            "prettifyLogMessage": false,
            "showCommonLabels": false,
            "showLabels": false,
            "showTime": true,
            "sortOrder": "Descending",
            "wrapLogMessage": true
          },
          "targets": [
            {
              "datasource": {
                "type": "loki",
                "uid": "loki"
              },
              "editorMode": "code",
              "expr": "{service_namespace=\"nerva\", service_name=\"$service\"} | (detected_level=~\"warn|error\" or event_name != \"\")",
              "queryType": "range",
              "refId": "A"
            }
          ],
          "title": "Logs relevantes del servicio",
          "type": "logs"
        },
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "description": "Trazas que contienen al servicio seleccionado dentro del período actual. Si no hay filas, ampliá el período.",
          "gridPos": {
            "h": 12,
            "w": 24,
            "x": 0,
            "y": 47
          },
          "fieldConfig": {
            "defaults": {
              "custom": {
                "align": "auto",
                "cellOptions": {
                  "type": "auto"
                },
                "inspect": false
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "startTime"
                },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 180
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "traceService"
                },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 190
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "traceName"
                },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 300
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "traceDuration"
                },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 110
                  }
                ]
              }
            ]
          },
          "id": 15,
          "options": {
            "cellHeight": "sm",
            "enablePagination": false,
            "footer": {
              "countRows": false,
              "fields": "",
              "reducer": [
                "sum"
              ],
              "show": false
            },
            "showHeader": true,
            "sortBy": [
              {
                "desc": true,
                "displayName": "Inicio"
              }
            ]
          },
          "targets": [
            {
              "datasource": {
                "type": "tempo",
                "uid": "tempo"
              },
              "limit": 20,
              "query": "{ resource.service.namespace = \"nerva\" && resource.service.name = \"$service\" } with (most_recent=true)",
              "queryType": "traceql",
              "refId": "A",
              "tableType": "traces"
            }
          ],
          "title": "Trazas recientes del servicio",
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "nested": true
                },
                "indexByName": {
                  "Start time": 0,
                  "Service": 1,
                  "Name": 2,
                  "Duration": 3,
                  "Trace ID": 4
                },
                "renameByName": {
                  "Start time": "Inicio",
                  "Duration": "Duración",
                  "Trace ID": "Traza",
                  "Name": "Operación inicial",
                  "Service": "Servicio inicial"
                }
              }
            }
          ],
          "type": "table"
        }
      ],
      "title": "Investigación del servicio",
      "type": "row"
    }
  ],
  "refresh": "15s",
