{
  "$schema": "./tokens.schema.json",
  "color": {
    "canvas": "#f7f9fc",
    "surface": "#ffffff",
    "surfaceSubtle": "#f8fafc",
    "text": "#172033",
    "textMuted": "#5b667a",
    "border": "#d9e0ea",
    "primary": "#1b365d",
    "primaryStrong": "#152b4a",
    "accent": "#0b74d1",
    "accentOnDark": "#8dccff",
    "accentSoft": "#eef6ff",
    "success": "#047857",
    "successSoft": "#ecfdf5",
    "warning": "#9a5b00",
    "warningSoft": "#fff5df",
    "danger": "#9f1239",
    "dangerBorder": "#fecdd3",
    "dangerSoft": "#fff1f2",
